# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings
# Storage bucket for PDF previews (create bucket "documents" in Supabase → Storage; run supabase_migration_document_storage.sql)
DOCUMENTS_BUCKET=documents

# Ollama (names must match `ollama list` — pull missing models with `ollama pull <name>`)
# If the backend runs in Docker on Mac/Windows, use http://host.docker.internal:11434 instead of localhost.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# RAG Settings
CHUNK_SIZE=300
CHUNK_OVERLAP=30
TOP_K=5

# CORS
CORS_ORIGINS=http://localhost:3000